# ============================================================
# Equivalent to netlify.toml + _headers, for Apache (Hostinger)
# ============================================================

RewriteEngine On

# ---- Same-origin page rewrites (Netlify status=200 = rewrite, not redirect) ----
RewriteRule ^pgrs/?$ /pgrs.html [L]
RewriteRule ^sobre/?$ /sobre.html [L]
RewriteRule ^contato/?$ /contato.html [L]
RewriteRule ^ecosystem/?$ /pmoc.html [L]
RewriteRule ^alias/?$ /vendas.html [L]
RewriteRule ^alias/suporte/?$ /alias-suporte.html [L]
RewriteRule ^alias/termos/?$ /alias-termos.html [L]
RewriteRule ^alias/privacidade/?$ /alias-privacidade.html [L]
RewriteRule ^ecosystem/suporte/?$ /alias-suporte.html [L]
RewriteRule ^ecosystem/termos/?$ /alias-termos.html [L]
RewriteRule ^ecosystem/privacidade/?$ /alias-privacidade.html [L]
RewriteRule ^ecosystem/callreception/?$ /vendas.html [L]
RewriteRule ^ecosystem/callreception/how-to-choose/?$ /how-to-choose-ai-receptionist.html [L]
RewriteRule ^ecosystem/callreception/real-cost-of-a-missed-call/?$ /real-cost-of-a-missed-call.html [L]
RewriteRule ^ecosystem/callreception/vs-smith-ai/?$ /aion-vs-smith-ai.html [L]
RewriteRule ^ecosystem/callreception/vs-goodcall/?$ /aion-vs-goodcall.html [L]
RewriteRule ^ecosystem/callreception/get-started/?$ /get-started.html [L]
RewriteRule ^ecosystem/callreception/vs-retell-ai/?$ /aion-vs-retell-ai.html [L]
RewriteRule ^ecosystem/callreception/vs-synthflow/?$ /aion-vs-synthflow.html [L]
RewriteRule ^ecosystem/callreception/ai-vs-answering-service/?$ /ai-receptionist-vs-answering-service.html [L]
RewriteRule ^ai-receptionist-guide/?$ /ai-receptionist-guide.html [L]

# ---- Blog (pretty URLs -> static files in /blog/) ----
RewriteRule ^blog/?$ /blog/index.html [L]
RewriteRule ^blog/ai-receptionist-for-small-business-guide/?$ /blog/ai-receptionist-for-small-business-guide.html [L]
RewriteRule ^blog/ai-receptionist-cost-2026/?$ /blog/ai-receptionist-cost-2026.html [L]
RewriteRule ^blog/signs-your-business-needs-ai-receptionist/?$ /blog/signs-your-business-needs-ai-receptionist.html [L]
RewriteRule ^blog/ai-receptionist-faq/?$ /blog/ai-receptionist-faq.html [L]
RewriteRule ^blog/ai-receptionist-vs-voicemail/?$ /blog/ai-receptionist-vs-voicemail.html [L]
RewriteRule ^blog/ai-receptionist-data-security/?$ /blog/ai-receptionist-data-security.html [L]
RewriteRule ^blog/what-industries-use-ai-receptionists/?$ /blog/what-industries-use-ai-receptionists.html [L]

# ---- Reverse-proxy to the Render backend, via PHP (mod_proxy returned 503
# on this hosting plan, so proxying is done in PHP/cURL instead) ----
RewriteRule ^artigos/(.*)$ /artigos.php?slug=$1 [L,QSA]
RewriteRule ^sitemap\.xml$ /sitemap.php [L]

# ============================================================
# Security headers (equivalent to _headers)
# ============================================================
<IfModule mod_headers.c>
  Header always set X-Frame-Options "SAMEORIGIN"
  Header always set X-Content-Type-Options "nosniff"
  Header always set Referrer-Policy "strict-origin-when-cross-origin"
  Header always set Content-Security-Policy "default-src 'self'; script-src 'self' 'unsafe-inline' 'unsafe-eval' https://*.googletagmanager.com https://*.google-analytics.com https://*.googleadservices.com https://*.doubleclick.net https://*.g.doubleclick.net https://*.google.com https://*.google.com.br https://*.googlesyndication.com https://cdnjs.cloudflare.com https://fonts.googleapis.com; script-src-elem 'self' 'unsafe-inline' 'unsafe-eval' https://*.googletagmanager.com https://*.google-analytics.com https://*.googleadservices.com https://*.doubleclick.net https://*.g.doubleclick.net https://*.google.com https://*.google.com.br https://*.googlesyndication.com https://cdnjs.cloudflare.com https://fonts.googleapis.com; connect-src 'self' https://engenheiro-producao-ai.onrender.com https://*.googletagmanager.com https://*.google-analytics.com https://*.analytics.google.com https://*.googleadservices.com https://*.doubleclick.net https://*.g.doubleclick.net https://*.google.com https://*.google.com.br https://*.googlesyndication.com; img-src 'self' data: blob: https://*.google.com https://*.google.com.br https://*.googleadservices.com https://*.doubleclick.net https://*.g.doubleclick.net https://*.googlesyndication.com https:; style-src 'self' 'unsafe-inline' https://fonts.googleapis.com https://cdnjs.cloudflare.com; font-src 'self' data: https://fonts.gstatic.com https://cdnjs.cloudflare.com; frame-src https://*.googletagmanager.com https://*.doubleclick.net https://*.google.com https://maps.google.com; object-src 'none'; base-uri 'self';"
</IfModule>
