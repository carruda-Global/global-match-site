# ============================================================
# Equivalent to netlify.toml + _headers, for Apache (Hostinger)
# ============================================================

RewriteEngine On

# ---- Canonical host: force www -> non-www (Semrush "duplicate title/content"
# finding, confirmed 2026-07-19: both hosts served identical pages with no
# redirect, e.g. www.global-engenharia.com/alias-termos.html and
# global-engenharia.com/alias-termos.html both 200). All canonical tags and
# the sitemap already use the non-www host, so that's the one kept live. ----
RewriteCond %{HTTP_HOST} ^www\.global-engenharia\.com$ [NC]
RewriteRule ^(.*)$ https://global-engenharia.com/$1 [L,R=301]

# ---- Same-origin page rewrites (Netlify status=200 = rewrite, not redirect) ----
RewriteRule ^pgrs/?$ /pgrs.html [L]
RewriteRule ^sobre/?$ /sobre.html [L]
RewriteRule ^contato/?$ /contato.html [L]
RewriteRule ^ecosystem/?$ /pmoc.html [L]
RewriteRule ^alias/?$ /vendas.html [L]
RewriteRule ^alias/suporte/?$ /alias-suporte.html [L]
RewriteRule ^alias/termos/?$ /alias-termos.html [L]
RewriteRule ^alias/privacidade/?$ /alias-privacidade.html [L]
RewriteRule ^ecosystem/suporte/?$ /alias-suporte.html [L]
RewriteRule ^ecosystem/termos/?$ /alias-termos.html [L]
RewriteRule ^ecosystem/privacidade/?$ /alias-privacidade.html [L]
RewriteRule ^ecosystem/callreception/?$ /vendas.html [L]
RewriteRule ^ecosystem/callreception/how-to-choose/?$ /how-to-choose-ai-receptionist.html [L]
RewriteRule ^ecosystem/callreception/real-cost-of-a-missed-call/?$ /real-cost-of-a-missed-call.html [L]
RewriteRule ^ecosystem/callreception/vs-smith-ai/?$ /aion-vs-smith-ai.html [L]
RewriteRule ^ecosystem/callreception/vs-goodcall/?$ /aion-vs-goodcall.html [L]
RewriteRule ^ecosystem/callreception/get-started/?$ /get-started.html [L]
RewriteRule ^ecosystem/callreception/vs-retell-ai/?$ /aion-vs-retell-ai.html [L]
RewriteRule ^ecosystem/callreception/vs-synthflow/?$ /aion-vs-synthflow.html [L]
RewriteRule ^ecosystem/callreception/ai-vs-answering-service/?$ /ai-receptionist-vs-answering-service.html [L]
RewriteRule ^ai-receptionist-guide/?$ /ai-receptionist-guide.html [L]

# ---- Blog (pretty URLs -> static files in /blog/) ----
RewriteRule ^blog/?$ /blog/index.html [L]
RewriteRule ^blog/ai-receptionist-for-small-business-guide/?$ /blog/ai-receptionist-for-small-business-guide.html [L]
RewriteRule ^blog/ai-receptionist-cost-2026/?$ /blog/ai-receptionist-cost-2026.html [L]
