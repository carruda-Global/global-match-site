RewriteRule ^blog/how-much-time-does-ai-receptionist-save/?$ /blog/how-much-time-does-ai-receptionist-save.html [L]
RewriteRule ^blog/can-i-listen-to-ai-receptionist-call-recordings/?$ /blog/can-i-listen-to-ai-receptionist-call-recordings.html [L]
