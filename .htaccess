RewriteRule ^blog/ai-receptionist-data-privacy-faq/?$ /blog/ai-receptionist-data-privacy-faq.html [L]
RewriteRule ^blog/can-ai-receptionist-answer-appointment-questions/?$ /blog/can-ai-receptionist-answer-appointment-questions.html [L]
RewriteRule ^blog/ai-receptionist-setup-time/?$ /blog/ai-receptionist-setup-time.html [L]
